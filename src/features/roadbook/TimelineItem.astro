---
interface Props {
  time?: string;
  title: string;
  description?: string;
  isLast?: boolean;
}

const { time, title, description, isLast = false } = Astro.props;
---

<div class:list={['flex gap-4', !isLast && 'pb-6']}>
  <div class="flex flex-col items-center shrink-0">
    <div class="w-3 h-3 rounded-full bg-yellow mt-1.5 shrink-0"></div>
    {!isLast && <div class="w-0.5 flex-1 bg-stroke mt-1"></div>}
  </div>
  <div class="flex-1 min-w-0 pb-0.5">
    {time && (
      <p class="inline-block text-[11px] font-sans font-bold text-race-black bg-yellow px-2 py-0.5 rounded-md uppercase tracking-wide mb-1">
        {time}
      </p>
    )}
    <p class="font-sans font-semibold text-base text-race-black leading-snug">{title}</p>
    {description && (
      <p class="text-sm text-muted mt-1 leading-snug">{description}</p>
    )}
    <slot />
  </div>
</div>
