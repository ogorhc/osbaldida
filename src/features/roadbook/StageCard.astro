---
import CategoryBadge from '@/components/ui/CategoryBadge.astro';
import type { Stage } from '@/data/stages';
import { CLIMBS } from '@/data/climbs';

interface Props {
  stage: Stage;
}

const { stage } = Astro.props;
const climbs = CLIMBS.filter((c) => stage.climbIds.includes(c.id));
---

<div class="bg-white rounded-lg overflow-hidden shadow-card">
  {stage.imageUrl ? (
    <div class="relative h-40 overflow-hidden">
      <img
        src={stage.imageUrl}
        alt={`${stage.label}: ${stage.route}`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-race-black/35 to-race-black/75" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 right-0 p-4">
        <p class="font-display font-bold text-white text-[18px] leading-tight">
          {stage.stageNumber && `Etapa ${stage.stageNumber} — `}{stage.day}
        </p>
        <p class="text-white/70 text-sm">{stage.date}</p>
      </div>
    </div>
  ) : (
    <div class="bg-race-black px-4 py-5">
      <p class="font-display font-bold text-white text-[18px] leading-tight">{stage.label}</p>
      <p class="text-white/70 text-sm">{stage.date}</p>
    </div>
  )}

  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-3">
      <p class="font-sans font-semibold text-base text-race-black">{stage.route}</p>
      <span
        class:list={[
          'text-[11px] font-sans font-bold px-2.5 py-1 rounded-md shrink-0',
          stage.isScoring ? 'bg-yellow text-race-black' : 'bg-surface text-muted',
        ]}
      >
        {stage.isScoring ? 'Puntuable' : 'Ceremonial'}
      </span>
    </div>

    {stage.isScoring && climbs.length > 0 && (
      <div class="-mx-4 px-4 flex gap-2 overflow-x-auto pb-1 mb-4 scrollbar-none">
        {climbs.map((climb) => (
          <span class="inline-flex shrink-0 items-center gap-1 bg-surface border border-stroke rounded-md px-1.5 py-0.5">
            <CategoryBadge category={climb.category} class="px-1 py-0 text-[10px] leading-none" />
            <span class="text-xs text-race-black font-medium whitespace-nowrap">
              {climb.name.replace(/^Alto (de |del )/, '')}
            </span>
          </span>
        ))}
      </div>
    )}

    {!stage.isScoring && (
      <p class="text-sm text-muted mb-4">{stage.summary}</p>
    )}

    <a
      href="/roadbook"
      class="inline-flex items-center gap-1.5 text-base font-sans font-semibold text-race-black active:opacity-70 tap-target -ml-1 px-1"
    >
      Ver programa
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</div>
