---
import Layout from '../components/layout/Layout.astro';
import PageContainer from '../components/layout/PageContainer.astro';
import Button from '../components/ui/Button.astro';
import JerseyCard from '../components/jerseys/JerseyCard.astro';
import ParticipantRow from '../components/participants/ParticipantRow.astro';
import StageCard from '../features/roadbook/StageCard.astro';
import { STAGES } from '../data/stages';
import { PARTICIPANTS } from '../data/participants';
import { TEAMS } from '../data/teams';
import { JERSEY_PATHS, JERSEY_FALLBACK_COLORS } from '../data/jerseys';

const teamByKey = Object.fromEntries(TEAMS.map((team) => [team.key, team]));
---

<Layout title="Inicio" description="Osbaldida 2026 — Despedida de Iker. Llodio → Angliru, 5–7 Junio 2026.">

  {/* ── Hero ──────────────────────────────────────────────────────────────── */}
  <section class="relative overflow-hidden bg-race-black min-h-dvh flex flex-col">
    <img
      src="/assets/stages/alto-del-angliru.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-50"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-race-black/30 to-race-black/85" aria-hidden="true"></div>
    <div class="relative z-10 flex flex-1 flex-col justify-between min-h-dvh px-5 pt-16 pb-nav md:pt-24 md:pb-12">
      <div>
        <span class="inline-block bg-yellow text-race-black text-[11px] font-sans font-bold uppercase tracking-widest px-3 py-1 rounded-md mb-4">
          5–7 Junio 2026
        </span>
        <h1 class="font-display font-bold text-white text-[40px] leading-[1.1] tracking-tight">
          Osbaldida<br/>2026
        </h1>
      </div>
      <div class="flex flex-col gap-3">
        <Button href="/clasificaciones" fullWidth>Ver clasificaciones</Button>
        <div class="flex gap-3">
          <Button href="/roadbook" variant="secondary" class="flex-1 border-white/30 text-white">
            Roadbook
          </Button>
          <Button href="/reglas" variant="secondary" class="flex-1 border-white/30 text-white">
            Reglas
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* ── Las etapas ────────────────────────────────────────────────────────── */}
  <section class="py-10 bg-bg">
    <PageContainer>
      <h2 class="section-title mb-5">Las etapas</h2>
      <div class="flex flex-col gap-4">
        {STAGES.map((stage) => <StageCard stage={stage} />)}
      </div>
    </PageContainer>
  </section>

  {/* ── Los maillots ──────────────────────────────────────────────────────── */}
  <section class="py-10 bg-surface">
    <PageContainer>
      <h2 class="section-title mb-1">Los maillots</h2>
      <p class="text-sm text-muted mb-5">Se entregan el sábado a la mañana.</p>
      <div class="flex flex-col gap-3">
        <JerseyCard
          imageSrc={JERSEY_PATHS.amarillo}
          imageAlt="Maillot amarillo"
          fallbackColor={JERSEY_FALLBACK_COLORS.amarillo}
          bgColor="#FFBE00"
          name="Maillot Amarillo"
          description="Para quien llegue más tarde al hotel el sábado. Selfie en el grupo obligatorio."
        />
        <JerseyCard
          imageSrc={JERSEY_PATHS.verde}
          imageAlt="Maillot verde"
          fallbackColor={JERSEY_FALLBACK_COLORS.verde}
          bgColor="#2A570D"
          name="Maillot Verde"
          description="Para el más regular en la fiesta. Se decide por votación colectiva."
        />
        <JerseyCard
          imageSrc={JERSEY_PATHS.puntos}
          imageAlt="Maillot de puntos"
          fallbackColor={JERSEY_FALLBACK_COLORS.puntos}
          bgColor="#B91C1C"
          name="Maillot de Puntos"
          description="Para el especialista en puertos puntuables. 7 puertos en 2 días."
        />
        <p class="font-sans font-semibold text-base text-race-black pt-2">Equipos</p>
        <p class="text-sm text-muted mb-1">Asignados por la organización antes del sábado.</p>
        {TEAMS.map((team) => (
          <JerseyCard
            imageSrc={team.jerseyPath}
            imageAlt={`Maillot ${team.name}`}
            fallbackColor={team.fallbackColor}
            bgColor={team.bgColor}
            name={team.name}
            description={team.description}
          />
        ))}
      </div>
    </PageContainer>
  </section>

  {/* ── El pelotón ────────────────────────────────────────────────────────── */}
  <section class="py-10 bg-bg">
    <PageContainer>
      <h2 class="section-title mb-1">El pelotón</h2>
      <p class="text-sm text-muted mb-5">{PARTICIPANTS.length} participantes</p>
      <div class="flex flex-col gap-2">
        {PARTICIPANTS.map((participant) => (
          <ParticipantRow
            participant={participant}
            team={participant.teamKey ? teamByKey[participant.teamKey] : null}
          />
        ))}
      </div>
    </PageContainer>
  </section>

  {/* ── Explora ───────────────────────────────────────────────────────────── */}
  <section class="py-10 bg-race-black">
    <PageContainer>
      <h2 class="section-title text-white mb-5">Explora</h2>
      <div class="grid grid-cols-2 gap-3">
        <a
          href="/clasificaciones"
          class="flex flex-col gap-1.5 bg-white/10 rounded-lg p-4 active:bg-white/20 tap-target"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-yellow" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
          <span class="font-sans font-semibold text-base text-white leading-tight">Clasificaciones</span>
        </a>
        <a
          href="/roadbook"
          class="flex flex-col gap-1.5 bg-white/10 rounded-lg p-4 active:bg-white/20 tap-target"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-yellow" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
          </svg>
          <span class="font-sans font-semibold text-base text-white leading-tight">Roadbook</span>
        </a>
        <a
          href="/galeria"
          class="flex flex-col gap-1.5 bg-white/10 rounded-lg p-4 active:bg-white/20 tap-target"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-yellow" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
          </svg>
          <span class="font-sans font-semibold text-base text-white leading-tight">Galería</span>
        </a>
        <a
          href="/reglas"
          class="flex flex-col gap-1.5 bg-white/10 rounded-lg p-4 active:bg-white/20 tap-target"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-yellow" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
          </svg>
          <span class="font-sans font-semibold text-base text-white leading-tight">Reglas</span>
        </a>
      </div>
    </PageContainer>
  </section>

</Layout>
